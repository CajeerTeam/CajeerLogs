      "url": "/logs?source=pwa-shortcut",
      "icons": [{ "src": "/assets/img/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Боты",
      "short_name": "Боты",
      "description": "Открыть здоровье ботов",
      "url": "/bots/health?source=pwa-shortcut",
      "icons": [{ "src": "/assets/img/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Система",
      "short_name": "Система",
      "description": "Открыть диагностику системы",
      "url": "/system?source=pwa-shortcut",
      "icons": [{ "src": "/assets/img/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ]
}

# Пример конфигурации Cajeer Logs.
# Скопируйте файл в .env и замените все значения change_me перед production-запуском.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://logs.example.com
APP_TIMEZONE=UTC
DOCS_URL=https://github.com/CajeerTeam/CajeerLogs/wiki

# База данных: в production используйте pgsql. SQLite допустим только для local/demo.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cajeer_logs
DB_USERNAME=cajeer_logs
DB_PASSWORD=change_me_use_a_strong_database_password
DB_SSLMODE=disable

# Сгенерируйте командой: openssl rand -hex 32
LOGS_TOKEN_PEPPER=change_me_generate_64_hex_chars
PRIVACY_HASH_PEPPER=change_me_generate_64_hex_chars
PRIVACY_HASH_IDENTIFIERS=true

# Аварийный вход через .env. После создания администратора держите выключенным.
LOGS_ENV_FALLBACK_LOGIN=false
LOGS_WEB_BASIC_USER=admin
LOGS_WEB_BASIC_PASSWORD=change_me_disable_fallback_after_first_admin
LOGIN_LOCKOUT_ATTEMPTS=8
UI_IP_ALLOWLIST=

# Лимиты и проверка ingest API.
INGEST_MAX_BATCH_SIZE=100
INGEST_MAX_BODY_BYTES=2097152
INGEST_REQUIRE_SIGNATURE=true
INGEST_SIGNATURE_SKEW_SECONDS=300
INGEST_MAX_MESSAGE_CHARS=8000
INGEST_MAX_EXCEPTION_CHARS=32768
INGEST_MAX_CONTEXT_BYTES=65536
INGEST_BULK_INSERT_ENABLED=true
INGEST_MAX_EVENTS_PER_MINUTE=3000
INGEST_MAX_BYTES_PER_MINUTE=10485760

# Импорт локальных журналов Nginx. Интеграция с aaPanel разрешена и поддерживается.
# NGINX_* — новые нейтральные имена. AAPANEL_* оставлены для совместимости с aaPanel layout.
NGINX_LOG_DIR=/www/wwwlogs
NGINX_LOG_PROJECT=Web Sites
NGINX_LOG_ENVIRONMENT=production
AAPANEL_LOG_DIR=/www/wwwlogs
AAPANEL_LOG_PROJECT=Web Sites
AAPANEL_LOG_ENVIRONMENT=production
AAPANEL_LOG_IMPORT_MAX_LINES=1000

# Оповещения. Если ALERT_WEBHOOK_ALLOWED_HOSTS задан, вебхуки разрешены только на эти хосты.
ALERT_WEBHOOK_ALLOWED_HOSTS=
ALERT_WEBHOOK_BLOCK_PRIVATE_DNS=true
ALERT_WEBHOOK_REQUIRE_ALLOWLIST=false
ALERT_WEBHOOK_TIMEOUT_SECONDS=5

# Лимиты UI и экспорта.
LOGS_EXPORT_MAX_ROWS=5000
LOGS_MAX_QUERY_LIMIT=5000

# Retention policy в днях.
RETENTION_DEBUG_DAYS=7
RETENTION_INFO_DAYS=30
RETENTION_WARN_DAYS=90
RETENTION_ERROR_DAYS=365
RETENTION_AUDIT_DAYS=730
RETENTION_AAPANEL_ACCESS_DAYS=30
RETENTION_AAPANEL_ERROR_DAYS=90
RETENTION_ARCHIVE_DAYS=30
RETENTION_ARCHIVE_BEFORE_DELETE=true

# Обновление из GitHub.
UPDATE_REPO_URL=https://github.com/CajeerTeam/CajeerLogs
UPDATE_BRANCH=main
UPDATE_MODE=git
UPDATE_ALLOW_WEB=false
UPDATE_BACKUP_DIR=storage/backups/updates
UPDATE_ROLLBACK_ON_FAILURE=true
UPDATE_GIT_BIN=git
UPDATE_PHP_BIN=php
# UPDATE_GITHUB_TOKEN=
